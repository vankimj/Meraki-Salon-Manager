{
  "expo": {
    "name": "Meraki Salon",
    "slug": "meraki-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "meraki",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1923"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2D7A5F",
      "iosDisplayInForeground": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meraki.salonmanager",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.721171829996-ap9a74l13h4c9rdtf4vv168c4kq1q5ep"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1923"
      },
      "package": "com.meraki.salonmanager",
      "useNextNotificationsApi": true
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D7A5F"
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "9da1f1fe-ab09-4f73-9367-0c67232234cc"
      }
    },
    "owner": "jvankim"
  }
}
